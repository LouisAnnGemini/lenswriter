{
  "entities": {
    "StoreState": {
      "title": "StoreState",
      "description": "The entire application state.",
      "type": "object",
      "properties": {
        "works": { "type": "array" },
        "characters": { "type": "array" },
        "chapters": { "type": "array" },
        "scenes": { "type": "array" },
        "blocks": { "type": "array" },
        "deadlines": { "type": "array" },
        "activeWorkId": { "type": "string" },
        "activeDocumentId": { "type": "string" },
        "activeTab": { "type": "string" },
        "activeLensId": { "type": "string" },
        "focusMode": { "type": "boolean" },
        "disguiseMode": { "type": "boolean" },
        "showDescriptions": { "type": "boolean" }
      }
    }
  },
  "firestore": {
    "/users/{userId}/data/state": {
      "schema": { "$ref": "StoreState" },
      "description": "The user's application state."
    }
  }
}
