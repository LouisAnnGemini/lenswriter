{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" }
      },
      "required": ["uid", "email"]
    },
    "Lens": {
      "title": "Lens",
      "description": "A lens containing content and metadata",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "documentId": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "isPinned": { "type": "boolean" },
        "notes": { "type": "string" },
        "linkedLensIds": { "type": "array" },
        "authorUid": { "type": "string" }
      },
      "required": ["id", "documentId", "authorUid"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document"
    },
    "/users/{userId}/lenses/{lensId}": {
      "schema": "Lens",
      "description": "User's lenses"
    }
  }
}
